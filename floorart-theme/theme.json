{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "black",      "color": "#111111", "name": "Black" },
        { "slug": "white",      "color": "#ffffff", "name": "White" },
        { "slug": "gray",       "color": "#444444", "name": "Gray" },
        { "slug": "light-gray", "color": "#f5f5f5", "name": "Light Gray" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Roboto Condensed', sans-serif",
          "slug": "roboto-condensed",
          "name": "Roboto Condensed"
        }
      ]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1600px"
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#111111"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--roboto-condensed)"
    }
  }
}
